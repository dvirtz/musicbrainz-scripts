export async function modifyArtistCreditBubble(bubble) {
  const form = bubble.querySelector("form");
  if (!form) {
    return;
  }
  const changeMatching = form?.querySelector("input#change-matching-artists");
  if (!changeMatching) {
    return;
  }
  if (await GM.getValue("change-matching-artists", false) && !changeMatching.checked) {
    changeMatching.click();
  }
}

